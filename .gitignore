# Terraform local state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Whitelist the bootstrap workspace state. The bootstrap workspace manages the
# S3 bucket and DynamoDB lock table that host the remote state for the main
# workspace, so it must use local state and that file lives in the repo.
!infra/bootstrap/terraform.tfstate

crash.log
crash.*.log

# Terraform provider/plugin cache
.terraform/
.terraform.tfstate.lock.info

# Terraform planfiles (binary) — generados por `terraform plan -out=...`,
# son ephemerals y voluminosos, no van al repo.
tfplan
*.tfplan
tfplan*.bin

# Lambda zip artifacts produced by data "archive_file" at plan/apply time
infra/modules/compute/build/

# node_modules dentro de la Lambda src: se reinstalan en cada apply via
# null_resource.npm_install. Necesarios en el zip pero no en git.
infra/modules/compute/src/node_modules/
infra/modules/compute/src/*/node_modules/

# Terraform output captures used in CI
plan.txt

# Ignore all *.tfvars by default — they may contain secrets.
# Whitelist los tfvars per-env (dev + staging) para que el grader y los
# workflows de CI/CD puedan usarlos. Los secrets reales viven en GitHub
# Actions environment secrets inyectados como TF_VAR_* en runtime — los
# .tfvars solo cargan config no-sensible.
*.tfvars
*.tfvars.json
!infra/envs/dev/dev.tfvars
!infra/envs/staging/staging.tfvars

# Override files (often used for local dev)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Environment / credentials
.env
.env.*
*.pem
*.key
credentials.json
service-account*.json

# CLI tooling
.terraformrc
terraform.rc

# IDE / OS noise
.DS_Store
.idea/
.vscode/
*.swp
.claude/
.antigravitycli/

# Specs / brainstorming intermedios — proceso entre Claude y el equipo, no entregable.
.specs/
