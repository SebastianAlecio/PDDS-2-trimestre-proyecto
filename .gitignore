# Terraform local state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Whitelist the bootstrap workspace state. The bootstrap workspace manages the
# S3 bucket and DynamoDB lock table that host the remote state for the main
# workspace, so it must use local state and that file lives in the repo.
!infra/bootstrap/terraform.tfstate

crash.log
crash.*.log

# Terraform provider/plugin cache
.terraform/
.terraform.tfstate.lock.info

# Terraform planfiles (binary)
tfplan
*.tfplan

# Lambda zip artifacts produced by data "archive_file" at plan/apply time
infra/modules/compute/build/

# Terraform output captures used in CI
plan.txt

# Ignore all *.tfvars by default — they may contain secrets.
# Whitelist the dev tfvars so the grader and CI can use it.
*.tfvars
*.tfvars.json
!infra/envs/dev/dev.tfvars

# Override files (often used for local dev)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Environment / credentials
.env
.env.*
*.pem
*.key
credentials.json
service-account*.json

# CLI tooling
.terraformrc
terraform.rc

# IDE / OS noise
.DS_Store
.idea/
.vscode/
*.swp
.claude/
